{
  "_comment": "HunterTrace Configuration — edit this file to tune thresholds without touching source code.",
  "_version": "2.0.0",

  "attribution": {
    "_comment": "Bayesian attribution engine thresholds (attributionEngine.py)",
    "tier_thresholds": {
      "tier4_isp_level":     0.85,
      "tier3_city_level":    0.70,
      "tier2_country_level": 0.50,
      "tier1_region_level":  0.25
    },
    "aci_layer_weights": {
      "tor":               0.30,
      "residential_proxy": 0.25,
      "vpn":               0.18,
      "timestamp_spoof":   0.12,
      "datacenter":        0.08
    },
    "signal_likelihood_ratios": {
      "real_ip_country":     18.0,
      "geolocation_country": 12.0,
      "isp_country":          8.0,
      "timezone_offset":      6.0,
      "timezone_region":      4.5,
      "vpn_exit_country":     2.5,
      "webmail_provider":     2.0,
      "send_hour_local":      1.8,
      "hop_pattern":          1.4,
      "subject_language":     1.3
    },
    "aci_floor": 0.05,
    "max_aci_adjusted_prob": 0.95,
    "min_signals_for_attribution": 1
  },

  "correlation": {
    "_comment": "Campaign correlator thresholds (campaignCorrelator.py)",
    "threshold_same_actor":  0.72,
    "threshold_likely_same": 0.50,
    "threshold_possible":    0.30,
    "min_cluster_size":      2,
    "signal_weights": {
      "timezone_offset":   0.20,
      "vpn_asn":           0.18,
      "send_hour_window":  0.15,
      "webmail_provider":  0.12,
      "dkim_domain":       0.10,
      "subject_structure": 0.08,
      "mail_client":       0.07,
      "hop_count":         0.05,
      "send_day_type":     0.03
    }
  },

  "ip_classification": {
    "_comment": "IP classifier thresholds (ipClassifier.py)",
    "abuseipdb_attacker_threshold":    75,
    "abuseipdb_suspicious_threshold":  25,
    "abuseipdb_residential_proxy_min": 40,
    "tor_refresh_interval_seconds":    3600,
    "api_rate_limit_delay_seconds":    0.5
  },

  "pipeline": {
    "_comment": "Main hunterTrace pipeline settings (hunterTrace.py)",
    "api_timeout_seconds":  10,
    "api_max_retries":       3,
    "api_backoff_factor":    1.5,
    "batch_max_workers":     4,
    "json_output_indent":    2
  },

  "evaluation": {
    "_comment": "Evaluation framework settings (evaluation_framework.py)",
    "test_split_ratio":       0.20,
    "cross_validation_folds": 5,
    "confidence_interval":    0.95,
    "calibration_bins":       10,
    "random_seed":            42
  },

  "logging": {
    "_comment": "Logging settings — level: DEBUG | INFO | WARNING | ERROR",
    "level":              "INFO",
    "log_to_file":        false,
    "log_file_path":      "hunterstrace.log",
    "log_rotate_mb":      10,
    "log_rotate_backups": 3
  }
}